# Required for the Gradio app and live OpenAI runs
OPENAI_API_KEY="your-openai-api-key"

# Optional: enable LangSmith / LangChain tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT="camp-assistant-e2e"

# Optional: use one of these for tracing auth
LANGCHAIN_API_KEY="your-langsmith-api-key"
# LANGSMITH_API_KEY="your-langsmith-api-key"

# Optional: enable live OpenAI E2E tests
E2E_USE_REAL_LLM=false
